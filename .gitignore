#
# JARs aren't checked in, they are fetched by sbt
#
/lib/*.jar
/test/files/codelib/*.jar
/test/files/lib/*.jar
/test/files/speclib/instrumented.jar
/tools/*.jar

# Developer specific properties
/build.properties
/buildcharacter.properties

# might get generated when testing Jenkins scripts locally
/jenkins.properties

# target directory for build
/build/
/generated-src/

# other
/out/
/bin/
/sandbox/

# intellij
/src/intellij*/*.iml
/src/intellij*/*.ipr
/src/intellij*/*.iws
**/.cache
/.idea
/.settings

# vscode
/.vscode

# language servers
/.bloop
/.metals

# Standard symbolic link to build/quick/bin
/qbin

# sbt's target directories
/target/
/chipyard/target/
/project/
/test/macro-annot/target/
/test/files/target/
/test/target/
/build-sbt/
local.sbt
jitwatch.out

# Used by the restarr/restarrFull commands as target directories
/build-restarr/
/target-restarr/

# metals
.metals
.bloop
project/**/metals.sbt

.bsp
.history

/src/test/resources/mxu_test_vectors
/src/test/resources/vpu_test_vectors

# Atlas baremetal generated artifacts
/baremetal/assembly/generated/
/baremetal/tests/atlas_*.c
/baremetal/tests/build/
/baremetal/results/
/baremetal/**/__pycache__/
/baremetal/generators/*.json
